{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "editor.insertSpaces": true,
  "editor.tabSize": 2,
  "editor.detectIndentation": false,
  "[typescript]": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[html]": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[scss]": {
    "editor.formatOnSave": true
  },
  "[css]": {
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "files.eol": "\r\n",
  "prettier.requireConfig": true,
  "eslint.validate": [
    "javascript",
    "typescript",
    "html"
  ],
  "eslint.format.enable": true,
  // "files.exclude": {
  //   "**/android": true,
  //   "**/android/.gradle": true,
  //   "**/android/build": true,
  //   "**/src-android": true,
  //   "**/src-tauri": true
  // },
  "search.exclude": {
    "**/android": true,
    "**/android/.gradle": true,
    "**/android/build": true,
    "**/src-android": true,
    "**/src-tauri": true
  },
  "files.watcherExclude": {
    "**/android/**": true,
    "**/src-android/**": true,
    "**/src-tauri/**": true
  },
  "rust-analyzer.files.excludeDirs": [
    "src-android",
    "src-tauri"
  ],
  "java.import.exclusions": [
    "android/**",
    "src-android/**",
    "src-tauri/**"
  ],
  "chat.tools.terminal.autoApprove": {
    "dir": true,
    "/^node dist/app/server/server\\.mjs$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^node scripts/ssr-batch-validate\\.js$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^node scripts/ssr-three-nevent-smoke\\.js$/": {
      "approve": true,
      "matchCommandLine": true
    }
  },
  "java.configuration.updateBuildConfiguration": "interactive"
}