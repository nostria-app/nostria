{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nostria",
  "version": "3.1.0",
  "identifier": "no.brainbox.nostria",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:4200",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/app/browser"
  },
  "app": {
    "windows": [
      {
        "title": "Nostria",
        "width": 900,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "dmg", "nsis", "msi"],
    "publisher": "Brainbox",
    "homepage": "https://nostria.app",
    "category": "SocialNetworking",
    "shortDescription": "Nostria is a decentralized Nostr client.",
    "longDescription": "Nostria is a decentralized Nostr client that offers a native desktop experience on Windows, Linux, and macOS.",
    "copyright": "Copyright (c) 2025 SondreB",
    "license": "MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "section": "web",
        "priority": "optional"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "allowDowngrades": false,
      "wix": {
        "language": "en-US",
        "upgradeCode": "eceda842-3f05-52aa-81b8-bd43bceecbab"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
