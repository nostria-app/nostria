{
  "name": "nostria",
  "version": "3.1.16",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 4200",
    "start-open": "ng serve --host 0.0.0.0 --port 4200",
    "version:patch": "node version.js",
    "build": "ng build",
    "build:tauri": "ng build && node scripts/prepare-tauri-dist.mjs",
    "build:ssr:prod": "ng build --configuration=production",
    "serve:ssr:prod": "npm run build:ssr:prod && npm run serve:ssr:app",
    "watch": "ng build --watch --configuration development",
    "gen:api": "ng-openapi-gen --input http://localhost:3000/openapi.json --output src/app/api --module false",
    "gen:i18n": "ng extract-i18n",
    "test": "ng test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:auth": "playwright test --grep @auth",
    "test:e2e:full": "playwright test --project=chromium",
    "test:e2e:ai": "playwright test --project=ai-debug",
    "test:e2e:metrics": "playwright test --project=ai-debug --grep @metrics",
    "test:e2e:report": "playwright show-report test-results/html-report",
    "test:e2e:visual": "playwright test --grep @visual --project=chromium",
    "test:e2e:visual:update": "playwright test --grep @visual --project=chromium --update-snapshots",
    "test:e2e:report:full": "npx ts-node e2e/helpers/report-generator.ts",
    "demo:feature": "node scripts/demo/run-demo-videos.mjs",
    "demo:all": "node scripts/demo/run-demo-videos.mjs --feature all --device both",
    "demo:auth-all": "node scripts/demo/run-demo-videos.mjs --feature auth --device both",
    "demo:auth-all:desktop": "node scripts/demo/run-demo-videos.mjs --feature auth --device desktop",
    "demo:auth-all:mobile": "node scripts/demo/run-demo-videos.mjs --feature auth --device mobile",
    "demo:showcase": "node scripts/demo/build-showcase-video.mjs --device desktop",
    "demo:showcase:mobile": "node scripts/demo/build-showcase-video.mjs --device mobile",
    "demo:scenes": "node scripts/demo/run-scenes-from-markdown.mjs",
    "demo:scenes:dry": "node scripts/demo/run-scenes-from-markdown.mjs --dry-run",
    "demo:compose": "node scripts/demo/compose-demo-videos.mjs",
    "gen:splash:ios": "powershell -ExecutionPolicy Bypass -File scripts/gen-ios-splash.ps1",
    "test:e2e:codegen": "playwright codegen http://localhost:4200",
    "tauri": "tauri",
    "tauri:info": "tauri info",
    "tauri:dev": "tauri dev",
    "tauri:android:icons": "powershell -ExecutionPolicy Bypass -File scripts/regenerate-tauri-android-icons.ps1",
    "tauri:android:dev": "powershell -ExecutionPolicy Bypass -File scripts/tauri-android-dev.ps1",
    "tauri:android:dev:emulator": "tauri android dev --host 10.0.2.2",
    "tauri:android:dev:device": "powershell -ExecutionPolicy Bypass -File scripts/tauri-android-dev.ps1 -PhysicalDevice",
    "tauri:android:build:packaged": "tauri android build --debug --apk",
    "tauri:android:build:debug": "tauri android build --debug --apk",
    "tauri:android:build:release": "tauri android build --apk",
    "tauri:android:build:release:local": "powershell -ExecutionPolicy Bypass -Command \"$env:TAURI_ANDROID_RELEASE_USE_DEBUG_KEY='true'; tauri android build --apk\"",
    "tauri:android:run:packaged": "tauri android run",
    "tauri:android:run:debug": "tauri android run",
    "tauri:android:run:release": "tauri android run --release",
    "tauri:android:run:release:local": "powershell -ExecutionPolicy Bypass -Command \"$env:TAURI_ANDROID_RELEASE_USE_DEBUG_KEY='true'; tauri android run --release\"",
    "tauri:build": "tauri build --ci",
    "tauri:build:linux": "tauri build --ci --bundles appimage,deb",
    "tauri:build:windows": "tauri build --ci --bundles nsis,msi",
    "tauri:build:windows:launch": "powershell -ExecutionPolicy Bypass -Command \"npm run tauri:build:windows; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; $binary = Resolve-Path 'src-tauri/target/release/nostria.exe'; Start-Process -FilePath $binary\"",
    "tauri:build:windows-arm": "tauri build --ci --target aarch64-pc-windows-msvc --bundles nsis,msi",
    "tauri:build:macos": "tauri build --ci --target universal-apple-darwin",
    "get-version": "node -p \"require('./package.json').version\"",
    "serve:ssr:app": "node dist/app/server/server.mjs",
    "debug:ssr:build": "ng build && ng run app:serve",
    "debug:ssr:serve": "node --inspect dist/app/server/server.mjs",
    "debug:ssr": "npm run debug:ssr:build && npm run debug:ssr:serve",
    "check:social-preview:beta": "powershell -ExecutionPolicy Bypass -File scripts/beta-social-preview-check.ps1",
    "check:social-preview:prod": "powershell -ExecutionPolicy Bypass -File scripts/prod-social-preview-check.ps1",
    "check:frame-protection": "node scripts/check-frame-protection.js",
    "lint": "ng lint",
    "lint-fix": "eslint . --ext .ts,.html --fix",
    "lint:check": "eslint . --ext .ts,.html --fix",
    "schemas": "npx vitest run schemata-validation.spec.ts --config vitest.config.ts"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/cdk": "^21.2.5",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/material": "^21.2.5",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-browser-dynamic": "^21.2.7",
    "@angular/platform-server": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@angular/service-worker": "^21.2.7",
    "@angular/ssr": "^21.2.6",
    "@cashu/cashu-ts": "^3.6.2",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/protest-strike": "^5.2.7",
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/sora": "^5.2.8",
    "@getalby/sdk": "^7.0.0",
    "@mediabunny/aac-encoder": "^1.40.1",
    "@microsoft/applicationinsights-web": "^3.3.11",
    "@noble/hashes": "^2.0.1",
    "@progress/jszip-esm": "^1.0.4",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-opener": "2.5.3",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@types/multer": "^2.1.0",
    "@xenova/transformers": "^2.17.2",
    "blurhash": "^2.0.5",
    "cors": "^2.8.6",
    "dompurify": "^3.3.3",
    "express": "^5.2.1",
    "hls.js": "^1.6.15",
    "html-to-image": "^1.11.13",
    "idb": "^8.0.3",
    "marked": "^17.0.5",
    "material-symbols": "^0.44.0",
    "mediabunny": "^1.40.1",
    "multer": "^2.1.1",
    "music-metadata": "^11.12.3",
    "nostr-tools": "^2.23.3",
    "qr": "^0.5.5",
    "rxjs": "~7.8.2",
    "thumbhash": "^0.1.1",
    "tslib": "^2.8.1",
    "web-haptics": "^0.0.6",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@angular/localize": "^21.2.7",
    "@nostrability/schemata": "^0.3.2",
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/express": "^5.0.6",
    "@types/hls.js": "^1.0.0",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "@vitest/browser-playwright": "^4.1.2",
    "ajv": "^8.18.0",
    "ajv-errors": "^3.0.0",
    "angular-eslint": "21.3.1",
    "dotenv": "^17.4.0",
    "eslint": "^9.39.4",
    "jsdom": "^29.0.1",
    "ng-openapi-gen": "^1.0.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.58.0",
    "vitest": "^4.1.2"
  }
}
